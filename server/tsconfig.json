{
  "include": ["./src"],
  "exclude": ["node_modules", "dist"],
  "compilerOptions": {
    "module": "CommonJS",
    "target": "ES2020",
    "moduleResolution": "node",
    "strict": false,
    "skipLibCheck": true,
    "declaration": false,
    "esModuleInterop": true,
    "resolveJsonModule": true
  }
}
