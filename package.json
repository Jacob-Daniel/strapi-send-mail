{
  "name": "strapi-plugin-send-mail",
  "version": "1.0.0",
  "description": "A Strapi v5 plugin for sending batch emails to subscriber groups using email templates.",
  "keywords": [
    "strapi",
    "strapi-plugin",
    "email",
    "batch-email",
    "newsletter",
    "subscribers",
    "send-mail"
  ],
  "homepage": "https://github.com/Jacob-Daniel/strapi-send-mail#readme",
  "bugs": {
    "url": "https://github.com/Jacob-Daniel/strapi-send-mail/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jacob-Daniel/strapi-send-mail.git"
  },
  "license": "MIT",
  "author": {
    "name": "Jacob Daniel",
    "url": "https://jacobdaniel.co.uk"
  },
  "type": "commonjs",
  "exports": {
    "./package.json": "./package.json",
    "./strapi-admin": {
      "types": "./dist/admin/src/index.d.ts",
      "source": "./admin/src/index.ts",
      "import": "./dist/admin/index.mjs",
      "require": "./dist/admin/index.js",
      "default": "./dist/admin/index.js"
    },
    "./strapi-server": {
      "types": "./dist/server/src/index.d.ts",
      "source": "./server/src/index.ts",
      "import": "./dist/server/index.mjs",
      "require": "./dist/server/index.js",
      "default": "./dist/server/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "strapi-plugin build",
    "watch": "strapi-plugin watch",
    "watch:link": "strapi-plugin watch:link",
    "verify": "strapi-plugin verify",
    "test:ts:front": "run -T tsc -p admin/tsconfig.json",
    "test:ts:back": "run -T tsc -p server/tsconfig.json"
  },
  "devDependencies": {
    "@strapi/design-system": "^2.2.0",
    "@strapi/icons": "^2.2.0",
    "@strapi/sdk-plugin": "^6.0.1",
    "@strapi/strapi": "^5.39.0",
    "@strapi/typescript-utils": "^5.39.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "prettier": "^3.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-intl": "^6.8.9",
    "react-router-dom": "^6.30.3",
    "styled-components": "^6.3.11",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@strapi/design-system": "^2.2.0",
    "@strapi/icons": "^2.2.0",
    "@strapi/sdk-plugin": "^6.0.1",
    "@strapi/strapi": "^5.39.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-intl": "^6.8.9",
    "react-router-dom": "^6.30.3",
    "styled-components": "^6.3.11"
  },
  "strapi": {
    "kind": "plugin",
    "name": "send-mail",
    "displayName": "Send Mail",
    "description": "Send batch emails to subscriber groups using email templates."
  }
}
